# Force LF line endings for shell scripts and config files (Linux server)
*.sh    text eol=lf
*.mjs   text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.conf  text eol=lf
*.sql   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.env   text eol=lf
